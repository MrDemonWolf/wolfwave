{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "//#tokens": {
      "inputs": [
        "design-system/tokens.json",
        "design-system/scripts/generate.ts"
      ],
      "outputs": [
        "apps/native/WolfWave/Core/DesignSystem/Tokens.generated.swift",
        "apps/docs/app/tokens.generated.css",
        "apps/native/WolfWave/Resources/widget-tokens.generated.js",
        "apps/marketing/shared/tokens.generated.ts"
      ]
    },
    "//#ds:lint": {
      "inputs": [
        "apps/native/WolfWave/Views/**/*.swift",
        "design-system/scripts/lint.ts",
        "design-system/lint-allowlist.txt"
      ]
    },
    "build": {
      "dependsOn": ["^build", "//#tokens", "widget#build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".source/**", "out/**"]
    },
    "widget#build": {
      "dependsOn": ["//#tokens"],
      "inputs": [
        "apps/widget/src/**",
        "apps/widget/tailwind.config.ts",
        "apps/widget/postcss.config.js",
        "apps/widget/build.ts",
        "apps/widget/package.json",
        "design-system/tokens.json"
      ],
      "outputs": [
        "apps/widget/dist/**",
        "apps/native/WolfWave/Resources/widget.html"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["//#tokens"]
    },
    "clean": {
      "cache": false
    }
  }
}
