############################################################
# macOS
############################################################
.DS_Store
**/.DS_Store
Icon\r

############################################################
# Xcode
############################################################
DerivedData/
build/

# User-specific data
xcuserdata/
*.xcuserstate
*.xccheckout
*.moved-aside
*.xcscmblueprint

# Project files that should not be committed
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Build artifacts
*.o
*.linkfilelist
*.hmap
*.ipa
*.dSYM
*.dSYM.zip
*.xcresult

# Xcode debugger data
xcdebugger/

############################################################
# Swift Package Manager
############################################################
/.build/
**/.build/
/.swiftpm/
# SwiftPM clone dir used by CI (`-clonedSourcePackagesDirPath SourcePackages`);
# a local build can populate it at repo root, so ignore the root copy.
/SourcePackages/
Package.pins
# For apps, keep Package.resolved tracked for reproducible builds.
# Uncomment the next line to ignore it (not recommended for apps):
# Package.resolved

############################################################
# IDEs
############################################################
.idea/
.vscode/

############################################################
# Temporary files
############################################################
*~
*.swp

############################################################
# Archives
############################################################
*.zip
*.tar.gz

############################################################
# Secrets / env
############################################################
.env
.env.*
apps/native/WolfWave/Config.xcconfig

# Local DMG/output folder created by Makefile prod build
builds/

# Local build/verify scratch dirs and stray tool output
/build_verify/
/Outdated

# Root node_modules (monorepo root)
node_modules/

############################################################
# Turborepo
############################################################
.turbo/

############################################################
# Widget (OBS overlay build artifacts)
############################################################
apps/widget/dist/

############################################################
# Docs (Next.js / Fumadocs)
############################################################
apps/docs/.next/

############################################################
# Marketing (Remotion)
############################################################
apps/marketing/*/out/

# Claude Code
.claude
docs/.next/
excalidraw.log
