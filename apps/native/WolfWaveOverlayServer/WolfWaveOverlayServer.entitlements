<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Minimal sandbox for the overlay server. Compared to the main app this drops
	  apple-events, keychain, and the Discord socket exception — the server only
	  needs to listen on a local TCP port. network.client is included so OBS/LAN
	  peers can reach the listener; network.server binds the listener itself.
	-->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
