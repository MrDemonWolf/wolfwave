// ============================================================================
// WolfWave Build Configuration (Example)
// ============================================================================
// SETUP INSTRUCTIONS:
// 1. Copy this file to Config.xcconfig
// 2. Replace placeholder values with your actual API keys
// 3. DO NOT commit Config.xcconfig to source control (it's in .gitignore)
//
// All values are expanded into Info.plist at build time.
// ============================================================================

// ----------------------------------------------------------------------------
// TWITCH CONFIGURATION
// ----------------------------------------------------------------------------
// Your Twitch Client ID for bot authentication
// Get one at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID = your_twitch_client_id_here

// ----------------------------------------------------------------------------
// DISCORD RICH PRESENCE
// ----------------------------------------------------------------------------
// Your Discord Application ID for Rich Presence integration
// Get one at: https://discord.com/developers/applications
// Shows "Listening to Apple Music" on your Discord profile
DISCORD_CLIENT_ID = your_discord_application_id_here

// ----------------------------------------------------------------------------
// AUTO-UPDATE CONFIGURATION
// ----------------------------------------------------------------------------
// GitHub repository information for Sparkle automatic updates
// The app checks: https://api.github.com/repos/{owner}/{repo}/releases/latest
// See SPARKLE_SETUP.md for complete setup instructions
GITHUB_REPO_OWNER = your_github_username
GITHUB_REPO_NAME = wolfwave

// ----------------------------------------------------------------------------
// FORK BRANDING (optional)
// ----------------------------------------------------------------------------
// Overrides for forks/whitelabels. Defaults match the upstream MrDemonWolf
// build — change these to point at your own docs site, community, and legal
// entity. Each value falls back to the upstream default if left blank.
//
// To rename the app itself, edit CFBundleDisplayName in Info.plist (or set
// PRODUCT_NAME in an xcconfig overlay — see Config.Debug.xcconfig).
// ----------------------------------------------------------------------------

// Documentation site root. Privacy/terms/changelog pages derive from this.
// NOTE: xcconfig treats "//" as a comment, which would silently truncate a URL
// to "https:". The "$()" expands to nothing and breaks up the "//" token so the
// full URL survives. Keep this escape on any value that contains "//".
DOCS_URL = https:/$()/mrdemonwolf.github.io/wolfwave

// Community Discord invite, opened from tray menu "Help > Join Discord Community".
COMMUNITY_DISCORD_URL = https:/$()/mrdwolf.net/discord

// Legal entity shown in About + Monthly Wrap footers.
COPYRIGHT_HOLDER = MrDemonWolf, Inc.

// ----------------------------------------------------------------------------
// ADVANCED: PER-ENVIRONMENT OVERRIDES
// ----------------------------------------------------------------------------
// Create Config.Debug.xcconfig or Config.Release.xcconfig to override values
// for specific build configurations. Assign in Project → Info → Configurations
// ----------------------------------------------------------------------------

